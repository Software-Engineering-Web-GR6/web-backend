APP_NAME=Smart Classroom Backend
APP_VERSION=1.0.0
ENVIRONMENT=development
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
DATABASE_URL=postgresql+asyncpg://smartclassroom:smartclassroom@localhost:5432/smart_classroom
TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:
DEFAULT_TEMP_WARNING=30
DEFAULT_TEMP_DANGER=35
DEFAULT_HUMIDITY_WARNING=80
DEFAULT_CO2_WARNING=1000
MQTT_ENABLED=true
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_SENSOR_TOPIC=smartclassrooms/sensors/readings
MQTT_DEVICE_COMMAND_TOPIC_PREFIX=smartclassrooms/devices
MQTT_DEVICE_ACK_TIMEOUT_SECONDS=1.5
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_sender_mailbox@gmail.com
SMTP_PASSWORD=REPLACE_WITH_GMAIL_APP_PASSWORD
SMTP_FROM_EMAIL=your_sender_mailbox@gmail.com
SMTP_USE_TLS=true
SIMULATOR_RESET_HISTORY_ON_START=false
