# Image published by GitHub Actions CD
BACKEND_IMAGE=ghcr.io/software-engineering-web-gr6/web-backend:latest
BACKEND_DOMAIN=api.example.com
ACME_EMAIL=ops@example.com

# PostgreSQL for docker-compose.prod.yml
POSTGRES_DB=smart_classroom
POSTGRES_USER=smartclassroom
POSTGRES_PASSWORD=change-this-strong-password

# Backend app settings
ENVIRONMENT=production
APP_NAME=Smart Classroom Backend
APP_VERSION=1.0.0
SECRET_KEY=replace-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
APP_TIMEZONE=Asia/Bangkok

# Rules and thresholds
DEFAULT_TEMP_WARNING=30
DEFAULT_TEMP_DANGER=35
DEFAULT_HUMIDITY_WARNING=80
DEFAULT_CO2_WARNING=1000

# MQTT settings
MQTT_ENABLED=true
MQTT_SENSOR_TOPIC=smartclassrooms/sensors/readings
MQTT_DEVICE_COMMAND_TOPIC_PREFIX=smartclassrooms/devices
MQTT_DEVICE_ACK_TIMEOUT_SECONDS=1.5

# Mail settings (set SMTP_ENABLED=false if not using email)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@smartclassroom.local
SMTP_USE_TLS=true

# Password reset
PASSWORD_RESET_CODE_EXPIRE_MINUTES=10
PASSWORD_RESET_CODE_LENGTH=6
PASSWORD_RESET_MAX_ATTEMPTS=5

# Simulator behavior
SIMULATOR_RESET_HISTORY_ON_START=false
